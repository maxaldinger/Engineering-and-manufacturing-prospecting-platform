# =============================================================================
# Anthropic (Sales Assist)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# ZoomInfo (Territory Signal Feed: company discovery + contact enrichment)
# =============================================================================
# The feed works without ZoomInfo (free public sources still populate it), but
# ZoomInfo is what turns it into real account + contact intelligence: territory
# company discovery, firmographics, installed CAM/CAD tech detection, and named
# decision-makers with emails and direct phones.
#
# ZoomInfo issues a 60-minute JWT; the app caches and auto-refreshes it.
# Verify your setup any time at:  GET /api/zoominfo/status?check=1
#
# --- Auth: use ONE of the two modes below ---

ZOOMINFO_USERNAME=your-zoominfo-username

# Mode A - PKI (recommended). Client ID + Private Key from ZoomInfo admin.
# Put the PEM key on ONE line, using literal \n for line breaks, e.g.:
#   ZOOMINFO_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
ZOOMINFO_CLIENT_ID=
ZOOMINFO_PRIVATE_KEY=

# Mode B - username/password (simpler). Leave the two PKI vars blank to use it.
ZOOMINFO_PASSWORD=

# --- Optional: override the API base URL (default https://api.zoominfo.com) ---
# ZOOMINFO_BASE_URL=https://api.zoominfo.com

# --- Optional: targeting + spend controls (defaults shown) ---
# ZoomInfo bills per enriched record, so these cap the fan-out per search.
# ZOOMINFO_MAX_COMPANIES=25          # companies discovered + enriched per pull (max 25)
# ZOOMINFO_FETCH_CONTACTS=true       # set false to skip contact enrichment entirely
# ZOOMINFO_CONTACT_COMPANIES=8       # how many top-fit companies get contacts
# ZOOMINFO_CONTACTS_PER_COMPANY=5    # contacts enriched per company
# ZOOMINFO_MIN_EMPLOYEES=0           # skip companies smaller than this (0 = no floor)
# ZOOMINFO_SIC_CODES=3559,3542,3728  # override the default manufacturing SIC set
# ZOOMINFO_NAICS_CODES=              # target by NAICS instead of SIC (optional)
